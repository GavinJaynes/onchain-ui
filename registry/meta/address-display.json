  "dependencies": [
    "viem",
    "sonner",
    "lucide-react"
  ],
  "devDependencies": [],
  "registryDependencies": [
    "sonner"
  ],
  "files": [
    {
      "path": "registry/onchain-ui/address-display.tsx",
      "type": "registry:ui",
      "target": "components/ui/address-display.tsx"
    },
    {
      "path": "lib/onchain/format.ts",
      "type": "registry:lib",
      "target": "lib/onchain/format.ts"
    }
  ]
