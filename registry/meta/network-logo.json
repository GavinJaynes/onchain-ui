{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "network-logo",
  "type": "registry:ui",
  "title": "Network Logo",
  "description": "Displays a network or chain logo with known chain fallbacks.",
  "docs": "```tsx\nimport { NetworkLogo } from \"@/components/ui/network-logo\"\n\n<NetworkLogo chainId={8453} name=\"Base\" />\n```",
  "dependencies": [
    "viem"
  ],
  "devDependencies": [],
  "registryDependencies": [
    "tooltip"
  ],
  "files": [
    {
      "path": "registry/onchain-ui/network-logo.tsx",
      "type": "registry:ui",
      "target": "components/ui/network-logo.tsx"
    },
    {
      "path": "lib/onchain/crypto-icons.tsx",
      "type": "registry:lib",
      "target": "lib/onchain/crypto-icons.tsx"
    }
  ]
}
