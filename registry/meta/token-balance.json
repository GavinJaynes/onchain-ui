{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "token-balance",
  "type": "registry:ui",
  "title": "Token Balance",
  "description": "Displays a token amount with optional logo, fiat value, and change.",
  "dependencies": ["lucide-react", "viem"],
  "devDependencies": [],
  "registryDependencies": ["tooltip"],
  "files": [
    {
      "path": "registry/onchain-ui/token-logo.tsx",
      "type": "registry:ui",
      "target": "components/ui/token-logo.tsx"
    },
    {
      "path": "registry/onchain-ui/token-price.tsx",
      "type": "registry:ui",
      "target": "components/ui/token-price.tsx"
    },
    {
      "path": "registry/onchain-ui/token-balance.tsx",
      "type": "registry:ui",
      "target": "components/ui/token-balance.tsx"
    },
    {
      "path": "lib/onchain/format.ts",
      "type": "registry:lib",
      "target": "lib/onchain/format.ts"
    },
    {
      "path": "lib/onchain/crypto-icons.tsx",
      "type": "registry:lib",
      "target": "lib/onchain/crypto-icons.tsx"
    }
  ]
}
