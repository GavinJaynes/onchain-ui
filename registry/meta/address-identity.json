{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "address-identity",
  "type": "registry:ui",
  "title": "Address Identity",
  "description": "Resolves an EVM address to an ENS or Base name with optional avatar, copy-to-clipboard, and explorer link.",
  "dependencies": ["viem", "sonner", "lucide-react"],
  "devDependencies": [],
  "registryDependencies": ["sonner"],
  "files": [
    {
      "path": "registry/onchain-ui/address-display.tsx",
      "type": "registry:ui",
      "target": "components/ui/address-display.tsx"
    },
    {
      "path": "registry/onchain-ui/address-identity.tsx",
      "type": "registry:ui",
      "target": "components/ui/address-identity.tsx"
    },
    {
      "path": "lib/onchain/format.ts",
      "type": "registry:lib",
      "target": "lib/onchain/format.ts"
    },
    {
      "path": "lib/onchain/resolvers.ts",
      "type": "registry:lib",
      "target": "lib/onchain/resolvers.ts"
    }
  ]
}
